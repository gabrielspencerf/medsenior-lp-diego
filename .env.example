# Copie para `.env` na raiz do projeto (não commitar segredos desnecessários).

# URL pública do site (https, sem barra final). Usada em canonical, og:url e imagens sociais no build.
# VITE_SITE_URL=https://www.seu-dominio.com.br

# WhatsApp de reserva (abre em nova aba se Typebot não estiver configurado)
# VITE_WHATSAPP_URL=https://wa.me/5511999999999

# Typebot — viewer self-hosted + ID público do fluxo (slug na URL)
# URL pública de referência: https://flow.creativelane.com.br/enanda-cwb
VITE_TYPEBOT_API_HOST=https://flow.creativelane.com.br
VITE_TYPEBOT_PUBLIC_ID=enanda-cwb
# Opcional: sobrescrever o script embed (padrão = jsDelivr @typebot.io/js@0, como no snippet do painel)
# VITE_TYPEBOT_JS_URL=https://cdn.jsdelivr.net/npm/@typebot.io/js@0/dist/web.js

# Google Tag Manager — apenas o ID do contentor (ex.: GTM-XXXXXXX)
# VITE_GTM_CONTAINER_ID=GTM-XXXXXXX

# Microsoft Clarity — ID do projeto no painel Clarity
# VITE_CLARITY_PROJECT_ID=xxxxxxxxxx
